<Window x:Class="UsageWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usage Limit Tracker"
        Width="280" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" ShowActivated="False"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <Style x:Key="MeterBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource Track}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track" CornerRadius="3"
                                    Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Indicator" CornerRadius="3"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="Card" CornerRadius="12" Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Padding="16,13,16,10"
            MouseLeftButtonDown="Card_MouseLeftButtonDown">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Refresh now" Click="Refresh_Click"/>
                <Separator/>
                <MenuItem x:Name="LockMenuItem" Header="Lock position" IsCheckable="True" Click="Lock_Click"/>
                <MenuItem x:Name="NotifyMenuItem" Header="Notifications" IsCheckable="True" Click="Notify_Click"/>
                <MenuItem x:Name="ThemeMenuItem" Header="Light theme" IsCheckable="True" Click="Theme_Click"/>
                <MenuItem x:Name="StartupMenuItem" Header="Start with Windows" IsCheckable="True" Click="Startup_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,9">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text="Claude" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkPrimary}" Margin="8,0,0,0"/>
                </StackPanel>
                <Border x:Name="PlanBadge" HorizontalAlignment="Right" VerticalAlignment="Center"
                        BorderBrush="{DynamicResource AccentSoft}" BorderThickness="1" CornerRadius="4"
                        Padding="5,1" Visibility="Collapsed">
                    <TextBlock x:Name="PlanText" FontSize="9.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource Accent}"/>
                </Border>
            </Grid>

            <!-- Accent divider -->
            <Rectangle Height="1.5" Fill="{DynamicResource AccentFade}" Margin="0,0,0,11"/>

            <!-- One row per limit -->
            <ItemsControl x:Name="LimitsList" IsHitTestVisible="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,10">
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="{Binding Label}" FontSize="11.5"
                                           Foreground="{DynamicResource InkSecondary}"/>
                                <TextBlock Text="{Binding PercentText}" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource InkPrimary}" HorizontalAlignment="Right"/>
                            </Grid>
                            <ProgressBar Style="{StaticResource MeterBar}"
                                         Value="{Binding Percent, Mode=OneWay}"
                                         Foreground="{Binding BarBrush}"/>
                            <TextBlock Text="{Binding ResetText}" FontSize="10.5"
                                       Foreground="{DynamicResource InkMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Shown instead of rows when there's no data yet -->
            <TextBlock x:Name="EmptyText" FontSize="11" Foreground="{DynamicResource InkSecondary}"
                       TextWrapping="Wrap" Margin="0,0,0,10" Visibility="Collapsed"/>

            <!-- Footer status -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#898781"
                         VerticalAlignment="Center" Margin="0,1,5,0"/>
                <TextBlock x:Name="StatusText" Text="loading…" FontSize="10"
                           Foreground="{DynamicResource InkMuted}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
