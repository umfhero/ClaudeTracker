<Window x:Class="UsageWidget.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight" MaxWidth="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True" ShowActivated="False"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Border CornerRadius="10" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1" Padding="14,11"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="SeverityDot" Width="8" Height="8" Fill="#FAB219"
                     VerticalAlignment="Top" Margin="0,5,0,0"/>
            <StackPanel Margin="10,0,0,0">
                <TextBlock x:Name="TitleText" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource InkPrimary}"/>
                <TextBlock x:Name="BodyText" FontSize="11.5" Foreground="{DynamicResource InkSecondary}"
                           TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
