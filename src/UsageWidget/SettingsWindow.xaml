<Window x:Class="UsageWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini API key" Width="360" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <Style x:Key="DlgButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Track}"/>
            <Setter Property="Foreground" Value="{DynamicResource InkPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="16,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Padding="18,16"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <StackPanel>
            <TextBlock Text="Gemini API key" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource InkPrimary}"/>
            <TextBlock FontSize="11" Foreground="{DynamicResource InkSecondary}" TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       Text="Paste a free Gemini API key and the widget will fetch one small project idea each day. Leave it empty to turn the feature off."/>
            <TextBlock FontSize="11" Margin="0,6,0,0">
                <Hyperlink NavigateUri="https://aistudio.google.com/apikey"
                           RequestNavigate="Link_RequestNavigate"
                           Foreground="{DynamicResource Accent}" TextDecorations="None">
                    Get a free key at aistudio.google.com
                </Hyperlink>
            </TextBlock>
            <Border Background="{DynamicResource Track}" CornerRadius="6" Padding="8,7" Margin="0,12,0,0">
                <TextBox x:Name="KeyBox" Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource InkPrimary}"
                         CaretBrush="{DynamicResource InkPrimary}" FontSize="12"/>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cancel" IsCancel="True" Click="Cancel_Click" Style="{StaticResource DlgButton}"/>
                <Button Content="Save" IsDefault="True" Click="Save_Click" Style="{StaticResource DlgButton}"
                        Background="{DynamicResource Accent}" Foreground="White" Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
